# Copy this file to .env and fill in your values.

# Get a free key at: https://otx.alienvault.com (sign up → My Profile → API Key)
OTX_API_KEY=your_otx_api_key_here

# VirusTotal API key — get a free key at: https://www.virustotal.com/gui/join-us
VT_API_KEY=your_virustotal_api_key_here

# AbuseIPDB API key — get a free key at: https://www.abuseipdb.com/
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# Slack or Discord Webhook URL for real-time alerting
WEBHOOK_URL=your_webhook_url_here
